# ==================================================
# Linux Lab Assignment
# .gitignore
# ==================================================

# ------------------------------
# Linux temporary files
# ------------------------------
*~
*.swp
*.swo
*.tmp

# ------------------------------
# macOS
# ------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ------------------------------
# Windows
# ------------------------------
Thumbs.db
Desktop.ini

# ------------------------------
# VS Code
# ------------------------------
.vscode/

# ------------------------------
# JetBrains IDEs
# ------------------------------
.idea/

# ------------------------------
# Vim swap files
# ------------------------------
*.sw?
Session.vim

# ------------------------------
# Log files
# ------------------------------
*.log

# ------------------------------
# Python cache (if any scripts are added later)
# ------------------------------
__pycache__/
*.pyc

# ------------------------------
# Temporary backup files
# ------------------------------
*.bak
*.old
*.orig

# ------------------------------
# Generated archives
# ------------------------------
*.zip
*.tar
*.tar.gz
*.7z
*.rar